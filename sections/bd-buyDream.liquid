{%- style -%}
  .buyDream {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 0 30px;

    @media (max-width: 992px) {
      padding: 15px;
    }
  }

  .buyDream-content {
    padding: 0 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 100%;
    border-radius: 32px;
    background-color: var(--chocolate-cosmos);

    @media (max-width: 992px) {
      padding: 30px;
      flex-direction: column;
      justify-content: center;
      gap: 30px;
    }

    @media (max-width: 767px) {
      padding: 30px 20px;
    }

    & img {
      max-width: 405px;
      max-height: 750px;
      height: 100%;
      width: 100%;
    }
  }

  .buyDream-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 20px;
    max-width: 400px;
    width: 100%;
    height: 100%;

    & p {
      font-size: clamp(12px, 16px, 24px);
      color: var(--old-lace);
    }

    & .bdbutton__primary {
      padding: 5px 30px;
      background-color: var(--chocolate-cosmos);
      color: var(--old-lace);
      transition: transform 0.3s ease;
      border: 1px solid var(--old-lace);
      transition: all 0.3s ease, color 0.3s ease;
      box-shadow: none;
    }

    & .bdbutton__primary:hover {
      color: var(--onyx);
      background-color: var(--old-lace);
      border: 1px solid var(--old-lace);
      box-shadow: 0px 10px 15px 0px rgba(0, 0, 0, 0.15), 0px 20px 35px 0px rgba(0, 0, 0, 0.25);
    }

    & ul {
      display: flex;
      flex-direction: column;
      gap: 30px;
      width: 100%;
    }

    & li {
      display: flex;
      justify-content: center;
      align-items: center;
      list-style: none;
      padding: 5px 10px;
      background-color: var(--old-lace);
      width: 100%;
      border-radius: 32px;
      color: var(--onyx);
      font-weight: 700;
      font-size: clamp(12px, 16px, 24px);
      font-family: var(--font-unbounded), sans-serif;
    }

    @media (max-width: 992px) {
      text-align: center;
      align-items: center;
      max-width: 100%;
    }
  }

  .buyDream-title {
    font-family: var(--font-unbounded), sans-serif;
    font-size: clamp(32px, 5vw, 48px);
    color: var(--old-lace);
    font-weight: 700;
    line-height: 1.1;
  }
{%- endstyle -%}

<section class="buyDream">
  <div class="buyDream-content">
    <div class="buyDream-container">
      <h2 class="buyDream-title">
        Why we <br>
        stand out?
      </h2>
      <p>
        Our secret lies in the unique dual texture: An incredibly soft, buttery cookie dough, fused with an explosive
        filling that always surprises.
      </p>
      <a href="{{ routes.all_products_collection_url }}" class="bdbutton bdbutton__primary">Taste It</a>
    </div>
    <img src="{{ 'bakedream-stack.png' | asset_url }}" alt="Stack of Bake Dream Cookies" width="405" height="750">
    <div class="buyDream-container">
      <ul>
        <li>Authentic Flavor</li>
        <li>Soft Texture</li>
        <li>Gourmet Treat</li>
      </ul>
    </div>
  </div>
</section>
