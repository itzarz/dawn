{%- style -%}
  .main-collection-container {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 0 30px 50px 30px;
    width: 100%;

    @media (max-width: 767px) {
      padding: 0 15px 30px 15px;
    }
  }

  .main-collection-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    gap: 20px;
    width: 100%;
    height: 80dvh;
    background: radial-gradient(50% 50% at 50% 50%, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 75%),
      linear-gradient(0deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.5) 100%),
      url('{{ "main-products-collection.JPG" | asset_url }}') lightgray 50% / cover no-repeat;
    border-radius: 32px;
    margin-bottom: 50px;
  }

  .main-collection-title {
    font-size: 40px;
    font-weight: 700;
    color: var(--snow);
    text-align: center;

    @media (max-width: 767px) {
      font-size: 32px;
    }
  }

  .main-collection-description {
    max-width: 700px;
    color: var(--snow);
    font-size: 20px;
    text-align: center;

    @media (max-width: 767px) {
      font-size: 16px;
    }
  }

  .main-collection-products__wrapper {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    justify-content: center;
    gap: 50px;
    width: 100%;
  }

  /* Product card */
  .bdproduct-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: var(--chocolate-cosmos);
    border-radius: 32px;
    text-decoration: none;
    box-shadow: 0 -4px 8px 0 rgba(0, 0, 0, 0.1) inset, 0 5px 10px 0 rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease;
  }
  .bdproduct-card__image-wrapper {
    position: relative;
    width: 100%;
    border-radius: 32px;
  }

  .bdproduct-card__image {
    width: 100%;
    object-fit: cover;
    aspect-ratio: 9 / 16;
    border-radius: 32px;
  }
  .bdproduct-card__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding: 30px 20px 40px 20px;
    width: 100%;
  }
  .bdproduct-card__title {
    font-size: clamp(12px, 16px, 24px);
    font-weight: 500;
    color: var(--old-lace);
  }

  /* Pricing */
  .bdproduct-card__pricing {
    display: flex;
    gap: 15px;
  }
  .product-price {
    font-family: var(--font-unbounded), sans-serif;
    font-size: clamp(12px, 16px, 20px);
    font-weight: 300;
  }
  .price--old {
    text-decoration: line-through;
    opacity: 0.6;
    color: var(--old-lace);
  }
  .price--sale {
    color: var(--old-lace);
  }

  /* Button */
  .bdproduct-card__button {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 30px;
    border: 2px solid var(--snow);
    background-color: var(--snow);
    color: var(--onyx);
    font-size: clamp(12px, 16px, 20px);
    font-weight: 500;
    border-radius: 24px;
    gap: 10px;
    cursor: pointer;
    transition: all 0.3s ease, color 0.3s ease;
  }
  .bdproduct-card__button:hover,
  .bdproduct-card__button:focus {
    border: 2px solid var(--chocolate-cosmos);
    background: var(--chocolate-cosmos);
    color: var(--old-lace);
  }
  .bdproduct-card__button:disabled {
    cursor: not-allowed;
    pointer-events: none;
    opacity: 0.5;
  }

  /* Badges */
  .badge {
    position: absolute;
    top: 20px;
    right: 20px;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: bold;
    color: var(--chocolate-cosmos);
    box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2);
  }
  .badge--sale {
    background: var(--chocolate-cosmos);
  }
  .badge--soldout {
    background: var(--onyx);
  }
{%- endstyle -%}

<section class="main-collection-container">
  <div class="main-collection-hero">
    <h1 class="main-collection-title">Our Cookies</h1>
    <p class="main-collection-description">
      Our New York–style cookies are made to surprise, comfort, and satisfy with every bite.
    </p>
  </div>
  <div class="main-collection-products__wrapper">
    {% for product in collection.products %}
      <a class="bdproduct-card" href="{{ product.url | within: collection }}">
        {% if product.compare_at_price > product.price %}
          <div class="badge badge--sale">On Sale</div>
        {% endif %}
        {% if product.available == false %}
          <div class="badge badge--soldout">Sold Out</div>
        {% endif %}
        <div class="bdproduct-card__image-wrapper">
          <img
            src="{{ product.featured_image | image_url: width: '320' , height: '400' }}"
            alt="{{ product.title }}"
            class="bdproduct-card__image"
            loading="lazy"
            width="320"
            height="400"
          >
          <form method="post" action="{{  routes.cart_add_url }}">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" class="quantity-input" min="3" value="3" readonly>
            <button
              type="submit"
              class="bdproduct-card__button"
              {% if product.available == false %}
                disabled
              {% endif %}
            >
              Add to Cart
            </button>
          </form>
        </div>
        <div class="bdproduct-card__content">
          <h3 class="bdproduct-card__title">{{ product.title }}</h3>
          <div class="product-card__pricing">
            {% if product.compare_at_price > product.price %}
              <span class="product-price price--old">{{ product.compare_at_price | money }}</span>
              <span class="product-price price--sale">{{ product.price | money }}</span>
            {% else %}
              <span class="product-price price--sale">{{ product.price | money }}</span>
            {% endif %}
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
