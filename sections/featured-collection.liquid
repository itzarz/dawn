{% assign collection = collections.all %}
{% assign max_products = settings.products_to_display | default: 8 %}

{%- style -%}
  h1,
  h2,
  h3,
  h4,
  a,
  button {
    font-family: var(--font-unbounded), sans-serif;
    font-weight: normal;
  }

  .featured-collection {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 80px;
    padding: 100px 30px 50px 30px;
    background-color: var(--old-lace);
    overflow: hidden;
  }

  .featured-collection__header {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;

    & h2 {
      font-size: clamp(2rem, 6vw, 4rem);
      font-weight: 700;
      color: var(--onyx);
      text-align: center;
    }

    & p {
      font-size: clamp(16px, 20px, 24px);
      color: var(--onyx);
      text-align: center;
    }
  }

  .featured-collection__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    text-align: center;

    & p {
      font-family: var(--font-ltcushion), sans-serif;
      font-size: clamp(12px, 20px, 24px);
      color: var(--onyx);
      line-height: 1.2;
      letter-spacing: 0px;
    }
  }

  /* Product card */
  .bdproduct-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: var(--chocolate-cosmos);
    border-radius: 32px;
    text-decoration: none;
    box-shadow: 0 -4px 8px 0 rgba(0, 0, 0, 0.1) inset, 0 5px 10px 0 rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease;
  }
  .bdproduct-card__image-wrapper {
    position: relative;
    width: 100%;
    border-radius: 32px;
  }

  .bdproduct-card__image {
    width: 100%;
    object-fit: cover;
    aspect-ratio: 9 / 16;
    border-radius: 32px;
  }
  .bdproduct-card__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding: 30px 20px 40px 20px;
    width: 100%;
  }
  .bdproduct-card__title {
    font-size: clamp(12px, 16px, 24px);
    font-weight: 500;
    color: var(--old-lace);
  }

  /* Pricing */
  .bdproduct-card__pricing {
    display: flex;
    gap: 15px;
  }
  .product-price {
    font-family: var(--font-unbounded), sans-serif;
    font-size: clamp(12px, 16px, 20px);
    font-weight: 300;
  }
  .price--old {
    text-decoration: line-through;
    opacity: 0.6;
    color: var(--old-lace);
  }
  .price--sale {
    color: var(--old-lace);
  }

  /* Button */
  .bdproduct-card__button {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 30px;
    border: 2px solid var(--snow);
    background-color: var(--snow);
    color: var(--onyx);
    font-size: clamp(12px, 16px, 20px);
    font-weight: 500;
    border-radius: 24px;
    gap: 10px;
    cursor: pointer;
    transition: all 0.3s ease, color 0.3s ease;
  }
  .bdproduct-card__button:hover,
  .bdproduct-card__button:focus {
    border: 2px solid var(--chocolate-cosmos);
    background: var(--chocolate-cosmos);
    color: var(--old-lace);
  }
  .bdproduct-card__button:disabled {
    cursor: not-allowed;
    pointer-events: none;
    opacity: 0.5;
  }

  /* Badges */
  .badge {
    position: absolute;
    top: 20px;
    right: 20px;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: bold;
    color: var(--chocolate-cosmos);
    box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2);
  }
  .badge--sale {
    background: var(--chocolate-cosmos);
  }
  .badge--soldout {
    background: var(--onyx);
  }

  .bdbutton {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 10px 30px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 32px;
    gap: 10px;
    border: 2px solid transparent;
    width: fit-content;
    font-size: clamp(12px, 14px, 16px);
    text-decoration: none;
    text-align: center;
    pointer-events: all;
    cursor: pointer;

    &.bdbutton__primary {
      background-color: var(--chocolate-cosmos);
      color: var(--old-lace);
      transition: transform 0.3s ease;
      border: 3px solid var(--chocolate-cosmos);
      transition: all 0.3s ease, color 0.3s ease;
    }

    &.bdbutton__primary:hover {
      color: var(--onyx);
      background-color: var(--dark-vanilla);
      border: 3px solid var(--dark-vanilla);
      box-shadow: 0px 10px 15px 0px rgba(0, 0, 0, 0.15), 0px 20px 35px 0px rgba(0, 0, 0, 0.25);
    }
  }

  @media (max-width: 1024px) {
    .featured-collection__header {
      align-items: center;
      text-align: center;

      & h2,
      p {
        text-align: center;
      }
    }
  }

  .splide {
    margin: 0 auto;
    width: 100%;
    padding: 40px 0;
  }

  .splide__pagination__page {
    background: var(--dark-vanilla);
  }

  .splide__pagination__page.is-active {
    background: var(--chocolate-cosmos);
  }

  .splide__arrow--prev {
    left: -3em;
  }

  .splide__arrow--next {
    right: -3em;
  }

  @media (max-width: 1024px) {
    .featured-collection {
      padding: 50px 15px;
    }
  }
{%- endstyle -%}

<section class="featured-collection">
  <div class="featured-collection__header">
    <h2 class="featured-collection__title">Best Sellers</h2>
    <p class="featured-collection__description">
      Discover our best-selling creations—soft, bold, and baked to perfection.
    </p>
  </div>
  <div class="splide" role="group" aria-label="Splide Basic HTML Example">
    <div class="splide__track">
      <ul class="splide__list">
        {% assign product_count = 0 %}
        {% for product in collection.products %}
          {% if product_count >= max_products %}
            {% break %}
          {% endif %}
          <li class="splide__slide">
            <a class="bdproduct-card" href="{{ product.url | within: collection }}">
              {% if product.compare_at_price > product.price %}
                <div class="badge badge--sale">On Sale</div>
              {% endif %}
              {% if product.available == false %}
                <div class="badge badge--soldout">Sold Out</div>
              {% endif %}
              <div class="bdproduct-card__image-wrapper">
                <img
                  src="{{ product.featured_image | image_url: width: '320' , height: '400' }}"
                  alt="{{ product.title }}"
                  class="bdproduct-card__image"
                  loading="lazy"
                  width="320"
                  height="400"
                >
                <form method="post" action="{{  routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <input type="hidden" name="quantity" class="quantity-input" min="3" value="3" readonly>
                  <button
                    type="submit"
                    class="bdproduct-card__button"
                    {% if product.available == false %}
                      disabled
                    {% endif %}
                  >
                    Add to Cart
                  </button>
                </form>
              </div>
              <div class="bdproduct-card__content">
                <h3 class="bdproduct-card__title">{{ product.title }}</h3>
                <div class="product-card__pricing">
                  {% if product.compare_at_price > product.price %}
                    <span class="product-price price--old">{{ product.compare_at_price | money }}</span>
                    <span class="product-price price--sale">{{ product.price | money }}</span>
                  {% else %}
                    <span class="product-price price--sale">{{ product.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
          </li>
          {% assign product_count = product_count | plus: 1 %}
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="featured-collection__footer">
    <p>Minimun order 3 cookies. Delivery & Pickup day every-day.</p>
    <a href="{{ collection.url }}" class="bdbutton bdbutton__primary"> Explore All <i data-lucide="cookie"></i></a>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var splide = new Splide('.splide', {
      perPage: 4,
      rewind: false,
      gap: '4rem',
      arrows: false,
      autoplay: true,
      interval: 3500,
      breakpoints: {
        1440: {
          perPage: 3,
        },
        1020: {
          perPage: 2,
        },
        640: {
          perPage: 1,
        },
      },
    });

    splide.mount();
  });
</script>
